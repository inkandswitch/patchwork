{
  "name": "@patchwork/os",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "module": "index.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite --force --port 5173",
    "build:main": "tsc && vite build",
    "build:sdk": "mkdir -p ./dist/sdk && cp -r ../sdk/dist/* ./dist/sdk/",
    "build:datagrid": "mkdir -p ./dist/datagrid && cp -r ../packages/datagrid/dist/* ./dist/datagrid",
    "build:essay": "mkdir -p ./dist/essay && cp -r ../packages/essay/dist/* ./dist/essay",
    "build:file": "mkdir -p ./dist/file && cp -r ../packages/file/dist/* ./dist/file",
    "build:folder": "mkdir -p ./dist/folder && cp -r ../packages/folder/dist/* ./dist/folder",
    "build:jacquard": "mkdir -p ./dist/jacquard && cp -r ../packages/jacquard/dist/* ./dist/jacquard",
    "build:kanban": "mkdir -p ./dist/kanban && cp -r ../packages/kanban/dist/* ./dist/kanban",
    "build:raw-editor": "mkdir -p ./dist/raw-editor && cp -r ../packages/raw-editor/dist/* ./dist/raw-editor",
    "build:tldraw": "mkdir -p ./dist/tldraw && cp -r ../packages/tldraw/dist/* ./dist/tldraw",
    "build:tools": "pnpm build:datagrid && pnpm build:essay && pnpm build:file && pnpm build:folder && pnpm build:jacquard && pnpm build:kanban && pnpm build:raw-editor && pnpm build:tldraw",
    "build:sw": "node ./build-service-worker.js",
    "build": "pnpm build:main && pnpm build:sdk && pnpm build:tools && node ./build-service-worker.js",
    "build:no-tsc": "vite build && node ./build-service-worker.js",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest"
  },
  "dependencies": {
    "@automerge/automerge": "2.2.9-alpha.2",
    "@automerge/automerge-repo": "2.0.0-alpha.7",
    "@automerge/automerge-repo-network-messagechannel": "2.0.0-alpha.7",
    "@automerge/automerge-repo-network-websocket": "2.0.0-alpha.7",
    "@automerge/automerge-repo-react-hooks": "2.0.0-alpha.7",
    "@automerge/automerge-repo-storage-indexeddb": "2.0.0-alpha.7",
    "@patchwork/counter": "workspace:*",
    "@patchwork/datagrid": "workspace:*",
    "@patchwork/engraft": "workspace:*",
    "@patchwork/essay": "workspace:*",
    "@patchwork/file": "workspace:*",
    "@patchwork/folder": "workspace:*",
    "@patchwork/jacquard": "workspace:*",
    "@patchwork/kanban": "workspace:*",
    "@patchwork/pkg": "workspace:*",
    "@patchwork/sequencer": "workspace:*",
    "@patchwork/raw-editor": "workspace:*",
    "@patchwork/sdk": "workspace:*",
    "@patchwork/tldraw": "workspace:*",
    "@tailwindcss/container-queries": "^0.1.1",
    "@xstate/react": "^4.1.1",
    "class-variance-authority": "^0.7.0",
    "esbuild": "^0.23.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.284.0",
    "react": "^18.3.1",
    "react-arborist": "^3.4.0",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^4.0.13",
    "react-markdown": "^9.0.1",
    "tailwindcss-animate": "^1.0.7",
    "use-resize-observer": "^9.1.0",
    "xstate": "^5.15.0"
  },
  "devDependencies": {
    "@jspm/generator": "^2.1.3",
    "@types/lodash": "^4.17.7",
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.9",
    "jsdom": "^22.1.0",
    "pnpm": "^8.15.9",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.4",
    "vite": "^5.3.4",
    "vite-plugin-top-level-await": "^1.4.2",
    "vite-plugin-wasm": "^3.3.0",
    "vitest": "^2.0.5"
  }
}
