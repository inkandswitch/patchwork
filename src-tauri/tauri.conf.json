{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Patchwork",
	"version": "0.1.0",
	"identifier": "com.inkandswitch.patchwork",
	"build": {
		"beforeDevCommand": "pnpm --filter tiny-patchwork dev",
		"devUrl": "http://localhost:5173",
		"beforeBuildCommand": "pnpm --filter tiny-patchwork build",
		"frontendDist": "../sites/tiny-patchwork/dist"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
