{
  "compilerOptions": {
    "rootDir": "src",
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "declaration": true,
    "lib": ["ESNext", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "paths": {
      "react": ["../../../../node_modules/@types/react"],
      "react-dom": ["../../../../node_modules/@types/react-dom"]
    }
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
