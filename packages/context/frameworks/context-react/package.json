{
  "name": "@patchwork/context-react",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w --preserveWatchOutput",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "push": "pnpm build && pushwork sync"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "dependencies": {
    "@automerge/automerge-repo": "catalog:",
    "@automerge/automerge-repo-react-hooks": "catalog:",
    "@patchwork/context": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "typescript": "^5.9.2"
  }
}
