    "@patchwork/context": "workspace:^",
    "@patchwork/context-diff": "workspace:^",
    "@patchwork/context-react": "workspace:^",
    "@patchwork/context-selection": "workspace:^",
    "@patchwork/element": "workspace:^",
    "@patchwork/filesystem": "workspace:^",
    "@patchwork/plugins": "workspace:^",
    "@patchwork/react": "workspace:^",
    "@tiny-patchwork/chat": "workspace:^",
    "lucide-react": "^0.469.0",
    "outdent": "^0.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "tailwindcss": "^4.0.9",
    "zod": "^4.1.12"
