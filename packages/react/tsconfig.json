{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "declaration": true,
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "paths": {
      "react": ["../../node_modules/@types/react"],
      "react-dom": ["../../node_modules/@types/react-dom"]
    }
  },
  "include": ["src"]
}
