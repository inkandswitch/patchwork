{
  "name": "@tiny-patchwork/agent",
  "version": "0.0.1",
  "description": "AI-powered document editor with chat interface",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "vite build",
    "push": "pushwork sync",
