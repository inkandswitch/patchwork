{
  "name": "@patchwork/monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "A malleable software environment for collaborative work",
  "main": "index.js",
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "rm -rf **/node_modules **/dist",
    "dev": "pnpm -r --parallel dev",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md,html,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md,html,yaml,yml}\"",
    "make-tool": "node scripts/make-tool.mjs",
    "preinstall": "npx only-allow pnpm",
    "preview": "pnpm --filter gaios preview",
    "test": "pnpm --filter \"./os\" test",
    "tsc": "pnpm -r exec tsc"
  },
  "pnpm": {
    "overrides": {
      "@automerge/automerge": "3.1.2",
      "@automerge/automerge-repo": "2.3.1"
    }
  },
  "keywords": [],
  "author": "Ink & Switch",
  "devDependencies": {
    "@vitest/ui": "^3.2.4",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vite": "^7.1.9",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "volta": {
    "node": "22.19.0"
  }
}
