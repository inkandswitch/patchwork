{
  "name": "@patchwork/essay-zip-export",
  "version": "0.0.1",
  "description": "Export an essay as a zip file with images",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "vite build",
    "push": "pnpm build && jacquard push",
    "watch": "nodemon --watch src -e js,tsx,ts,tsx,css,json --exec 'pnpm build && pnpm push'"
  },
  "dependencies": {
    "@patchwork/sdk": "workspace:*",
    "@patchwork/essay": "workspace:*",
    "@patchwork/file": "workspace:*",
    "@automerge/automerge": "2.2.9-alpha.4",
    "@automerge/automerge-repo": "2.0.0-alpha.7",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@vitejs/plugin-react": "^4.3.1",
    "nodemon": "^3.1.9",
    "vite": "^5.3.4",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-top-level-await": "^1.4.2",
    "vite-plugin-wasm": "^3.3.0"
  }
}
