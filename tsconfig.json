{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    "paths": {
      "@/*": ["./packages/core/src/*"],
      "@patchwork/sdk": ["./packages/core/src/os/sdk.ts"],
      "@automerge/automerge-wasm": ["./packages/core/src/vendor/automerge-wasm/index.d.ts"]
    },

    /* Linting */
    // "strict": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true
  },
  "include": ["packages"],
  "exclude": ["packages/core/src/vendor"]
}
