{
  "name": "@patchwork/monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "A malleable software environment for collaborative work",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "bin": {
    "pw-modules": "./scripts/module-settings/register-module",
    "patchwork-modules": "./scripts/module-settings/register-module"
  },
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 pnpm -r build",
    "clean": "pnpm -r exec rm -rf node_modules dist && rm -rf node_modules",
    "dev": "pnpm -r --filter ...{sites/${SITE:-patchwork.inkandswitch.com}}... --parallel dev",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md,html,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md,html,yaml,yml}\"",
    "link-cli": "pnpm --ignore-workspace --dir scripts/module-settings install && pnpm link --global",
    "preinstall": "npx only-allow pnpm",
    "preview": "pnpm --filter patchwork.inkandswitch.com preview",
    "publish-packages": "changeset publish",
    "test": "vitest run",
    "tsc": "pnpm -r exec tsc",
    "watch": "pnpm --filter @inkandswitch/patchwork... --parallel --if-present dev"
  },
  "keywords": [],
  "author": "Ink & Switch",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "cross-env": "^10.1.0",
    "prettier": "^3.8.3",
    "typescript": "catalog:",
    "vite": "^7.3.5",
    "vitest": "^3.2.6"
  },
  "volta": {
    "node": "24.11.1"
  }
}
