{
  "name": "@inkandswitch/patchwork-e2e",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inkandswitch/patchwork-next.git",
    "directory": "packages/e2e"
  },
  "version": "0.1.1",
  "type": "module",
  "description": "Browser + Service-Worker end-to-end sync tests (Playwright) for a Patchwork site.",
  "bin": {
    "patchwork-e2e": "./bin/patchwork-e2e.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "exports": {
    "./helpers": {
      "import": "./dist/tests/helpers.js",
      "types": "./dist/tests/helpers.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && cp -R fixtures dist/fixtures",
    "dev": "tsc -w --preserveWatchOutput",
    "prepare": "pnpm build",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "report": "playwright show-report"
  },
  "dependencies": {
    "@playwright/test": "1.59.1"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
