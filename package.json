{
  "name": "@patchwork/monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "A malleable software environment for collaborative work",
  "main": "index.js",
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "pw-modules": "./scripts/module-settings/register-module",
    "patchwork-modules": "./scripts/module-settings/register-module"
  },
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 pnpm -r --filter '!tenfold.inkandswitch.com' --workspace-concurrency=1 build",
    "clean": "rm -rf **/node_modules **/dist",
    "dev": "pnpm -r --filter ...{sites/${SITE:-tiny-patchwork}}... --parallel dev",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md,html,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md,html,yaml,yml}\"",
    "link-cli": "pnpm --ignore-workspace --dir scripts/module-settings install && pnpm link --global",
    "preinstall": "npx only-allow pnpm",
    "preview": "pnpm --filter gaios preview",
    "publish-packages": "pnpm -r publish --access=public",
    "test": "pnpm --filter \"./os\" test",
    "tsc": "pnpm -r exec tsc"
  },
  "keywords": [],
  "author": "Ink & Switch",
  "devDependencies": {
    "@automerge/automerge-repo": "catalog:",
    "@automerge/automerge-subduction": "catalog:",
    "@changesets/cli": "^2.31.0",
    "@vitest/ui": "^3.2.6",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.6"
  },
  "volta": {
    "node": "24.11.1"
  },
  "dependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:"
  }
}
