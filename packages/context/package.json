{
  "name": "@patchwork/context",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w --preserveWatchOutput",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "push": "pnpm build && pushwork sync"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/frameworks/react.js",
      "types": "./dist/frameworks/react.d.ts"
    },
    "./solid": {
      "import": "./dist/frameworks/solid.js",
      "types": "./dist/frameworks/solid.d.ts"
    },
    "./diff": {
      "import": "./dist/apis/diff.js",
      "types": "./dist/apis/diff.d.ts"
    },
    "./selection": {
      "import": "./dist/apis/selection.js",
      "types": "./dist/apis/selection.d.ts"
    },
    "./comments": {
      "import": "./dist/apis/comments.js",
      "types": "./dist/apis/comments.d.ts"
    }
  },
  "dependencies": {
    "@automerge/automerge": "^3.1.2",
    "@automerge/automerge-repo": "^2.3.0",
    "@automerge/automerge-repo-react-hooks": "^2.3.0",
    "eventemitter3": "^5.0.1",
    "react": "^18.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@types/react": "^19.1.10",
    "@typescript-eslint/parser": "^8.40.0",
    "eslint": "^9.34.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "solid-js": "^1.9.9",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0",
    "vite": "^7.1.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  }
}
